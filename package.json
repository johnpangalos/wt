{
  "name": "wt",
  "version": "0.1.0",
  "description": "Pick and switch git worktrees from the shell. Opens each worktree in a new tmux/zellij window.",
  "bin": {
    "wt": "./bin/wt"
  },
  "scripts": {
    "build": "bun build src/cli.ts --compile --minify --outfile bin/wt",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && bun test",
    "test:fast": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.2"
  }
}
